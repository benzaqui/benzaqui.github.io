# LLM Provider API Keys (following preference: Anthropic > OpenAI > Google)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# AWS Configuration for Kendra Knowledge Base
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
KENDRA_INDEX_ID=your_kendra_index_id_here

# ServiceNow Integration (if direct API access needed)
SNOW_INSTANCE_URL=https://your-instance.service-now.com
SNOW_USERNAME=your_snow_username
SNOW_PASSWORD=your_snow_password

# LangSmith Configuration for Monitoring
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=helpdesk-email-routing

# Email Processing Configuration
EMAIL_PROCESSING_TIMEOUT=30
MAX_EMAIL_SIZE_MB=10

# Routing Configuration
DEFAULT_ROUTING_QUEUE=general-support
ESCALATION_QUEUE=tier2-support
HIGH_PRIORITY_THRESHOLD=0.8
KNOWLEDGE_BASE_CONFIDENCE_THRESHOLD=0.7

# Human-in-the-Loop Configuration
ENABLE_HUMAN_REVIEW=true
AUTO_ESCALATE_TIMEOUT_MINUTES=30

# Development Configuration
LOG_LEVEL=INFO
DEBUG_MODE=false
ENABLE_STRUCTURED_LOGGING=true

# Optional Web Interface Configuration
STREAMLIT_SERVER_PORT=8501
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
